{
  "manifest_version": 3,
  "name": "Neuro-Inclusive Web",
  "version": "2.0.0",
  "description": "AI-powered cognitive accessibility for ADHD, Autism, and Dyslexia",
  "permissions": ["storage", "activeTab", "tabs", "scripting", "alarms"],
  "host_permissions": ["<all_urls>", "https://api-inference.huggingface.co/*", "https://generativelanguage.googleapis.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-dyslexic-font": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Toggle Dyslexia-Friendly Font"
    },
    "toggle-soft-colors": {
      "suggested_key": {
        "default": "Ctrl+Shift+C",
        "mac": "Command+Shift+C"
      },
      "description": "Toggle Soft Colors"
    },
    "toggle-remove-distractions": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Toggle Remove Distractions"
    },
    "toggle-reading-ruler": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Toggle Reading Ruler"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Neuro-Inclusive Web",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
  {
    "resources": ["autism-game.html", "autism-game.js", "dyslexia-game.html", "dyslexia-game.js", "adhd-game.html", "adhd-game.js"],
    "matches": ["<all_urls>"]
  }
],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}


